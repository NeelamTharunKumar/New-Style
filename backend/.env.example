# BharatFit AI backend environment
BHARATFIT_ENV=production
BHARATFIT_APP_NAME=BharatFit AI Backend

# Optional API key guard. If set, clients must send X-API-Key.
BHARATFIT_API_KEY=change-me

# Comma-separated frontend/app origins. Use exact domains in production.
BHARATFIT_CORS_ORIGINS=https://your-app.example.com
BHARATFIT_LOG_REQUESTS=true

# Persistence. SQLite example:
DATABASE_URL=sqlite:///./bharatfit.db

# Postgres example:
# DATABASE_URL=postgresql+psycopg://bharatfit:bharatfit@postgres:5432/bharatfit

# Optional explanation-only LLM adapter
BHARATFIT_LLM_ENABLED=false
OPENAI_API_KEY=
BHARATFIT_LLM_MODEL=gpt-4o-mini
BHARATFIT_LLM_TIMEOUT_SECONDS=20
