# Drape AI backend environment
DRAPE_ENV=production
DRAPE_APP_NAME=Drape AI Backend

# Optional API key guard. If set, clients must send X-API-Key.
DRAPE_API_KEY=change-me

# User auth/isolation. Options: open_dev, dev_bearer, static_bearer, firebase.
DRAPE_AUTH_MODE=open_dev
# For static_bearer mode: comma-separated token:user_id pairs.
DRAPE_USER_TOKENS=
# For firebase mode. GOOGLE_APPLICATION_CREDENTIALS may also be used.
FIREBASE_PROJECT_ID=
DRAPE_FIREBASE_CREDENTIALS_PATH=

# Comma-separated frontend/app origins. Use exact domains in production.
DRAPE_CORS_ORIGINS=https://your-app.example.com
DRAPE_LOG_REQUESTS=true

# Persistence. SQLite example:
DATABASE_URL=sqlite:///./drape.db

# Postgres example:
# DATABASE_URL=postgresql+psycopg://drape:drape@postgres:5432/drape

# Optional explanation-only LLM adapter
DRAPE_LLM_ENABLED=false
OPENAI_API_KEY=
DRAPE_LLM_MODEL=gpt-4o-mini
DRAPE_LLM_TIMEOUT_SECONDS=20
